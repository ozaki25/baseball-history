{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist",
    ".output",
    ".nitro",
    ".tanstack",
    "node_modules",
    "src/routeTree.gen.ts"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "off",
    "unicorn/no-array-sort": "off",
    "no-underscore-dangle": "off"
  },
  "overrides": [
    {
      "files": ["src/components/**", "src/routes/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/lib/ingest/*", "#/lib/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアント(components/routes)から import しないでください。取り込み専用モジュールです。"
              }
            ]
          }
        ]
      }
    }
  ]
}
