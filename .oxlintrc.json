{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist",
    ".output",
    ".nitro",
    ".tanstack",
    "node_modules",
    "src/routeTree.gen.ts"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "off",
    "unicorn/no-array-sort": "off",
    "no-underscore-dangle": "off"
  },
  "overrides": [
    {
      "files": ["src/ui/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/features/**", "#/lib/**", "#/routes/**", "#/types/**"],
                "message": "ui/ はドメイン非依存の再利用UIです。domain型・lib・features に依存する部品は features/ に置いてください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/lib/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/features/**", "#/ui/**", "#/routes/**"],
                "message": "lib は最下層の共有モジュールです。features/ui/routes に依存させないでください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/routes/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/lib/ingest/*", "#/lib/ingest/**", "**/lib/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/home/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/lib/ingest/*", "#/lib/ingest/**", "**/lib/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              },
              {
                "group": ["#/routes/**"],
                "message": "features は routes に依存させないでください（依存は routes → features の一方向）。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/filters/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/lib/ingest/*", "#/lib/ingest/**", "**/lib/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              },
              {
                "group": ["#/routes/**"],
                "message": "features は routes に依存させないでください（依存は routes → features の一方向）。"
              },
              {
                "group": ["#/features/home/**", "#/features/stats/**", "#/features/games/**"],
                "message": "feature 間の横断依存は禁止です（画面合成は features/home のみが担います）。共有ロジックは lib/ へ。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/stats/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/lib/ingest/*", "#/lib/ingest/**", "**/lib/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              },
              {
                "group": ["#/routes/**"],
                "message": "features は routes に依存させないでください（依存は routes → features の一方向）。"
              },
              {
                "group": ["#/features/home/**", "#/features/filters/**", "#/features/games/**"],
                "message": "feature 間の横断依存は禁止です（画面合成は features/home のみが担います）。共有ロジックは lib/ へ。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/games/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/lib/ingest/*", "#/lib/ingest/**", "**/lib/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              },
              {
                "group": ["#/routes/**"],
                "message": "features は routes に依存させないでください（依存は routes → features の一方向）。"
              },
              {
                "group": ["#/features/home/**", "#/features/filters/**", "#/features/stats/**"],
                "message": "feature 間の横断依存は禁止です（画面合成は features/home のみが担います）。共有ロジックは lib/ へ。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["scripts/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/features/**", "#/ui/**", "#/routes/**"],
                "message": "scripts(ビルド/取り込み)はUI層に依存しないでください。共有ロジックは lib/ へ置いてください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/types/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/features/**", "#/ui/**", "#/lib/**", "#/routes/**"],
                "message": "types は最下層のドメイン型です。features/ui/lib/routes に依存させないでください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/*.test.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
