{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist",
    ".output",
    ".nitro",
    ".tanstack",
    "node_modules",
    "src/routeTree.gen.ts"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "off",
    "unicorn/no-array-sort": "off",
    "no-underscore-dangle": "off"
  },
  "overrides": [
    {
      "files": ["src/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/ingest/**", "**/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              },
              {
                "group": ["**/data/**/*.json", "**/data/**/*.json?*"],
                "message": "data/*.json の直読みは src/data/** ゲートウェイのみの特権です。ALL_GAMES/ALL_YEARS を import してください（?raw/?url 等のクエリ回避・サブディレクトリ回避も禁止）。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/data/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "#/features/**",
                  "#/screens/**",
                  "#/app/**",
                  "#/ui/**",
                  "#/routes/**",
                  "#/ingest/**",
                  "**/ingest/**"
                ],
                "message": "data は最下層のビルド時ゲートウェイです。UI 層(features/screens/app/ui/routes)・ingest には依存させないでください（JSON 直読みは data 内では許可）。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/ingest/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "#/features/**",
                  "#/screens/**",
                  "#/app/**",
                  "#/ui/**",
                  "#/routes/**",
                  "#/data/**"
                ],
                "message": "ingest は取り込み専用モジュールです。UI 層(features/screens/app/ui/routes)・data に依存させないでください。共有ロジックは domain/ へ。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/ui/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "#/features/**",
                  "#/screens/**",
                  "#/app/**",
                  "#/domain/**",
                  "#/routes/**",
                  "#/data/**",
                  "#/ingest/**",
                  "**/ingest/**",
                  "**/data/**/*.json",
                  "**/data/**/*.json?*"
                ],
                "message": "ui/ はドメイン非依存の再利用UIです。domain・data・features・screens・app・routes・ingest に依存する部品は features/ に置いてください（相対パス/クエリ回避も禁止）。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/domain/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "#/features/**",
                  "#/screens/**",
                  "#/app/**",
                  "#/ui/**",
                  "#/routes/**",
                  "#/data/**",
                  "#/ingest/**",
                  "**/ingest/**",
                  "**/data/**/*.json",
                  "**/data/**/*.json?*"
                ],
                "message": "domain は framework 非依存の最下層（型・参照データ・純ロジック）です。上位のいかなる層(features/screens/app/ui/routes/data/ingest)にも依存させないでください（相対パス/クエリ回避も禁止）。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/routes/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/ingest/**", "**/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              },
              {
                "group": ["**/data/**/*.json", "**/data/**/*.json?*"],
                "message": "data/*.json の直読みは src/data/** ゲートウェイのみの特権です。ALL_GAMES/ALL_YEARS を import してください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/app/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "#/features/**",
                  "#/screens/**",
                  "#/routes/**",
                  "#/data/**",
                  "#/ingest/**",
                  "**/ingest/**",
                  "**/data/**/*.json",
                  "**/data/**/*.json?*"
                ],
                "message": "app/ はアプリ全体の外殻(AppShell 等)。features/screens/routes/data/ingest には依存させないでください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/screens/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/ingest/**", "**/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              },
              {
                "group": ["#/routes/**"],
                "message": "screens は routes に依存させないでください（依存は routes → screens → features の一方向）。"
              },
              {
                "group": ["**/data/**/*.json", "**/data/**/*.json?*"],
                "message": "data/*.json の直読みは src/data/** ゲートウェイのみの特権です。ALL_GAMES/ALL_YEARS を import してください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["#/ingest/**", "**/ingest/**"],
                "message": "ingest系(jsdom依存)はクライアントから import しないでください。取り込み専用モジュールです（相対パス回避も禁止）。"
              },
              {
                "group": ["#/routes/**", "#/screens/**", "#/app/**"],
                "message": "features は routes/screens/app に依存させないでください（依存は routes → app/screens → features の一方向）。"
              },
              {
                "group": ["**/data/**/*.json", "**/data/**/*.json?*"],
                "message": "data/*.json の直読みは src/data/** ゲートウェイのみの特権です。ALL_GAMES/ALL_YEARS を import してください。"
              },
              {
                "group": ["#/data/**"],
                "message": "features は data ゲートウェイに直接依存させないでください（consuming は screens/routes の役割）。"
              },
              {
                "group": ["#/features/**"],
                "message": "feature 兄弟の import は禁止（同一 feature 内は相対 import で完結）。画面横断の合成は screens/ の役割・共有ロジックは domain/ へ。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["scripts/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "#/features/**",
                  "#/screens/**",
                  "#/app/**",
                  "#/ui/**",
                  "#/routes/**",
                  "#/data/**"
                ],
                "message": "scripts(ビルド/取り込み)はUI層・dataゲートウェイに依存しないでください。共有ロジックは domain/ へ置いてください。"
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/*.test.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
